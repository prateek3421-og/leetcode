class Solution {
    public int[] rearrangeArray(int[] nums) {
        int[] ans=new int[nums.length];
        
        int neg=1;
        int pos=0;

        for(int i=0;i<nums.length;i++){
            if(nums[i]<0){
                ans[neg]=nums[i];
                neg+=2;
            }
            else {
                ans[pos]=nums[i];
                pos+=2;
            }
        }
            return ans;

        
    }
}
