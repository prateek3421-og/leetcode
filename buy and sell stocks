class Solution {
    public int maxProfit(int[] nums) {
        int mini=nums[0];
        int maxprofit=0;
        for(int i=0;i<nums.length;i++){
            int cost=nums[i]-mini;
            maxprofit=Math.max(maxprofit,cost);
            mini=Math.min(mini,nums[i]);


        }
        return maxprofit;
              
    }
}
