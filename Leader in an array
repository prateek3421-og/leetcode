class Solution {
    public List<Integer> leaders(int[] nums) {
        ArrayList<Integer> list = new ArrayList<>();
        int maxi=Integer.MIN_VALUE;
        int n = nums.length;

        for(int i = n-1;i>=0;i--){
            if(nums[i]>maxi){
                list.add(nums[i]);
            }
            maxi=Math.max(maxi,nums[i]);
                   }


        Collections.reverse(list);
        return list;
    }
}
