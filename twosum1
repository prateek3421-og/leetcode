class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap<Integer,Integer> mpp=new HashMap<>();
        int n = nums.length ;

        for(int i =0;i<n;i++){
            int num=nums[i];
            int remain= target-num;
            if(mpp.containsKey(remain)){
                return new int[]{mpp.get(remain),i};
            }
            mpp.put(num,i);
        }
        return new int[] {-1,-1};
        
        
    }
}
